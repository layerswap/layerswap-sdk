{
  "name": "@layerswap/sdk",
  "version": "0.3.0",
  "description": "Lightweight TypeScript client for the Layerswap API",
  "author": "Layerswap <support@layerswap.io>",
  "license": "Apache-2.0",
  "repository": "github:layerswap/layerswap-sdk",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run tests/client.test.ts",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
